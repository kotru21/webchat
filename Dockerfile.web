# Multi-stage SPA image: Vite build → nginx with CSP + reverse proxy to API.
# syntax=docker/dockerfile:1

FROM node:26-bookworm-slim AS build
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY index.html vite.config.js jsconfig.json tailwind.config.js ./
COPY public ./public
COPY src ./src
# Same-origin behind the reverse proxy — leave VITE_API_URL unset.
RUN npm run build

# Pinned manifest digest for nginx:1.27.5-alpine (multi-arch).
FROM nginx:1.27.5-alpine@sha256:65645c7bb6a0661892a8b03b89d0743208a18dd2f3f17a54ef4b76fb8e2f2a10
COPY deploy/nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s \
  CMD wget -qO- http://127.0.0.1/healthz >/dev/null || exit 1
